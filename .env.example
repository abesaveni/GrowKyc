# Server
PORT=3001
NODE_ENV=development
LOCAL_DEV=true
FRONTEND_URL=http://localhost:5173

# AWS Cognito (Authentication)
COGNITO_USER_POOL_ID=ap-southeast-2_XXXXXXXXX
COGNITO_APP_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
AWS_REGION=ap-southeast-2

# AWS S3 (Document Storage)
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
S3_EVIDENCE_BUCKET=growkyc-evidence-prod
S3_STAGING_BUCKET=growkyc-staging-prod
S3_REGION=ap-southeast-2

# AWS SES (Email)
SES_FROM_EMAIL=noreply@yourdomain.com
SES_FROM_NAME=GrowKYC Compliance
SES_REGION=ap-southeast-2

# Supabase (Database)
SUPABASE_URL=https://XXXXXXXXXX.supabase.co
SUPABASE_ANON_KEY=eyJXXXXXXXXXXXXX
SUPABASE_SERVICE_ROLE_KEY=eyJXXXXXXXXXXXXX

# Frontend (Vite) — these are exposed to the browser, use VITE_ prefix
VITE_SUPABASE_URL=https://XXXXXXXXXX.supabase.co
VITE_SUPABASE_ANON_KEY=eyJXXXXXXXXXXXXX
VITE_API_URL=http://localhost:3001
VITE_BACKEND_PROVIDER=supabase-bridge

# Screening Providers (leave blank to use graceful degradation)
SANCTIONS_API_URL=
SANCTIONS_API_KEY=
PEP_API_URL=
PEP_API_KEY=
ADVERSE_MEDIA_API_URL=
ADVERSE_MEDIA_API_KEY=
IDV_API_URL=
IDV_API_KEY=
REGISTRY_API_URL=
REGISTRY_API_KEY=

# InfoTrack (KYC)
INFOTRACK_API_URL=https://api.infotrack.com.au
INFOTRACK_CLIENT_ID=
INFOTRACK_CLIENT_SECRET=

# GreenID (Identity Verification)
GREENID_API_URL=https://test-api.greenid.com
GREENID_API_CODE=
GREENID_API_PASSWORD=

# Equifax (Credit)
EQUIFAX_API_URL=https://api.equifax.com.au
EQUIFAX_CLIENT_ID=
EQUIFAX_CLIENT_SECRET=

# Xero (Accounting)
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:3001/api/integrations/xero/callback

# ASIC / ABR (Government Registries)
ABR_GUID=
ASIC_API_KEY=

# Stripe (Payments)
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXX

# DocuSign (E-Signature)
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET_KEY=
DOCUSIGN_BASE_URL=https://demo.docusign.net

# PEXA (Property Exchange)
PEXA_API_URL=https://api.pexa.com.au
PEXA_API_KEY=

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Feature Flags
ENABLE_AI_COPILOT=true
ENABLE_FRAUD_DETECTION=false
ENABLE_REAL_SCREENING=false
ALLOW_PLACEHOLDER_SCREENING_ADAPTERS=true

# Security
SESSION_SECRET=change-me-to-a-long-random-string-in-production
ENCRYPTION_KEY=change-me-to-32-chars-exactly-00
