# Backend API URL (FastAPI on port 8000)
# In development the Vite proxy handles /api/* → localhost:8000, so this is optional.
# Set it for a staging/production deployment where the frontend is served separately.
VITE_API_BASE_URL=http://localhost:8000

# Supabase Configuration
# These VITE_ prefixed vars are exposed to the browser bundle via Vite
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Legacy / server-side aliases (used by some adapters)
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_or_service_key

# AWS S3 Storage Configuration
AWS_REGION=ap-southeast-2
AWS_BUCKET_NAME=your_evidence_bucket_name
AWS_S3_BUCKET_NAME=your_evidence_bucket_name
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_KMS_KEY_ID=your_optional_kms_key_id
AWS_S3_ENDPOINT=

# Screening Providers Configuration
ALLOW_PLACEHOLDER_SCREENING_ADAPTERS=true

# Equifax
EQUIFAX_API_KEY=your_equifax_api_key
EQUIFAX_SECRET=your_equifax_secret
EQUIFAX_BASE_URL=https://api.equifax.com

# Illion
ILLION_API_KEY=your_illion_api_key
ILLION_BASE_URL=https://api.illion.com.au

# Sanctions
SANCTIONS_API_KEY=your_sanctions_api_key
SANCTIONS_API_BASE_URL=https://api.sanctions.io

# PEXA OAuth2 + Webhooks
PEXA_CLIENT_ID=your_pexa_oauth_client_id
PEXA_CLIENT_SECRET=your_pexa_oauth_client_secret
PEXA_BASE_URL=https://api.pexa.com.au/v1
PEXA_WEBHOOK_SECRET=your_pexa_webhook_hmac_secret
