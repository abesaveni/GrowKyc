# ===== Database Configuration =====
# PostgreSQL connection string (recommended for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/kyc_db

# SQLite connection string (default for development)
DATABASE_URL=sqlite:///./kyc.db

# Enable SQL echo for debugging (log all SQL queries)
SQL_ECHO=false


# ===== JWT Configuration =====
# Secret key for JWT token signing - CHANGE THIS IN PRODUCTION!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production-12345678

# JWT algorithm (HS256 is recommended)
JWT_ALGORITHM=HS256

# Access token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30


# ===== Server Configuration =====
# Server host and port
HOST=0.0.0.0
PORT=8000

# Environment: development or production
ENV=development

# Log level: debug, info, warning, error, critical
LOG_LEVEL=info


# ===== CORS Configuration =====
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000


# ===== Optional: File Upload Configuration =====
# Maximum upload file size in MB
MAX_UPLOAD_SIZE_MB=10

# Upload directory path
UPLOAD_DIR=./uploads
